# ============================================================
# Flowz Backend — variáveis de ambiente
# Copie para .env e preencha os valores reais
# ============================================================

# Servidor Express
PORT=3001

# ── Supabase ─────────────────────────────────────────────────
# Encontre em: Supabase Dashboard → Settings → API
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=seu_service_role_key
SUPABASE_ANON_KEY=seu_anon_key

# ── Frontend (CORS) ──────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Evolution API (WhatsApp) ─────────────────────────────────
# URL onde a Evolution API está rodando (Docker local ou VPS)
EVOLUTION_API_URL=http://localhost:8080
# Chave global definida no .env da Evolution API
EVOLUTION_API_KEY=sua_chave_global_evolution
# URL pública do backend para receber webhooks da Evolution API
# Em produção: https://api.seudominio.com.br
# Em dev local: use ngrok → https://abc123.ngrok.io
EVOLUTION_WEBHOOK_URL=http://localhost:3001

# ── N8N (Automações e Agente IA) ─────────────────────────────
# URL onde o N8N está rodando
N8N_URL=http://localhost:5678
# Segredo para validar que o webhook veio do Flowz (coloque no Header Auth do N8N)
N8N_WEBHOOK_SECRET=seu_segredo_n8n_aqui
# Path do webhook N8N para o agente IA (configure no Workflow Trigger Node)
N8N_AI_WEBHOOK_PATH=flowz-ai-agent
